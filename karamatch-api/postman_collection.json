                {
                    "name": "Decline notification",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/notifications/:id/decline",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "notifications", ":id", "decline"],
                            "variable": [{ "key": "id", "value": "{{notificationId}}" }]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Dev",
            "item": [
                {
                    "name": "Reset database",
                    "request": {
                        "auth": { "type": "noauth" },
                        "method": "POST",
                        "header": [],
                        "url": { "raw": "{{baseUrl}}/api/dev/reset", "host": ["{{baseUrl}}"], "path": ["api", "dev", "reset"] },
                        "description": "Resets the database to seed data. No auth required."
                    },
                    "response": []
                }
            ]
        }
    ]
}
